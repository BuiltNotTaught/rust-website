# Copy to .env and fill in what you need. Everything here is optional.
PORT=3000
SITE_URL=https://example.com

# Cloudflare Turnstile (spam protection on the contact form).
# With no keys set, the widget is hidden and the form still works.
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Emailing contact submissions via SendGrid. Without these, messages are
# still saved to the database, just not emailed.
SENDGRID_API_KEY=
CONTACT_TO_EMAIL=
CONTACT_FROM_EMAIL=
