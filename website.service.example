# Example systemd unit. Copy to /etc/systemd/system/website.service and edit paths.
[Unit]
Description=Rust site
After=network.target

[Service]
Type=simple
User=www-data
WorkingDirectory=/opt/website
ExecStart=/opt/website/rust-site-template
Environment=PORT=3000
# Uncomment to bind port 80 directly as a non-root user:
# AmbientCapabilities=CAP_NET_BIND_SERVICE
Restart=on-failure
RestartSec=5s

[Install]
WantedBy=multi-user.target
